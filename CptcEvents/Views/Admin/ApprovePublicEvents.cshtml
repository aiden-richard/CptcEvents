@model CptcEvents.Models.ViewModels.ApprovePublicEventsViewModel

@{
    ViewData["Title"] = "Approve Public Events";
}

<div class="page-shell">
    <div class="d-flex justify-content-between align-items-start flex-wrap gap-2 mb-3">
        <div>
            <p class="text-muted small mb-1">Admin</p>
            <h2 class="mb-0">Approve Public Events</h2>
        </div>
        <div class="d-flex flex-wrap gap-2">
            <a class="btn btn-outline-secondary" href="@Url.Action("Index", "Admin")">Back to admin</a>
        </div>
    </div>

    <!-- Pending Approval Section -->
    <div class="card shadow-sm mb-4" id="pending-section">
        <div class="card-header bg-warning text-dark">
            <h5 class="mb-0">Pending Approval</h5>
        </div>
        <div class="card-body">
            @if (Model.PendingEvents.TotalCount > 0)
            {
                <p class="text-muted small mb-3">@Model.PendingEvents.TotalCount event(s) pending approval</p>
                <div class="table-responsive">
                    <table class="table align-middle">
                        <thead>
                            <tr>
                                <th>Title</th>
                                <th>Group</th>
                                <th>Date</th>
                                <th>Time</th>
                                <th>Created By</th>
                                <th class="text-end">Actions</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var evt in Model.PendingEvents.Items)
                            {
                                <tr>
                                    <td><strong>@evt.Title</strong></td>
                                    <td>@evt.Group?.Name</td>
                                    <td>@evt.DateOfEvent.ToString("yyyy-MM-dd")</td>
                                    <td>
                                        @if (evt.IsAllDay)
                                        {
                                            <span>All day</span>
                                        }
                                        else
                                        {
                                            <span>@evt.StartTime.ToString("hh\\:mm") - @evt.EndTime.ToString("hh\\:mm")</span>
                                        }
                                    </td>
                                    <td>
                                        @if (evt.CreatedByUser != null)
                                        {
                                            <small>@evt.CreatedByUser.UserName</small>
                                        }
                                    </td>
                                    <td class="text-end">
                                        <a class="btn btn-sm btn-outline-primary" href="@Url.Action("Details", "Events", new { eventId = evt.Id })">Review Event</a>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
                @if (Model.PendingEvents.TotalPages > 1)
                {
                    <nav aria-label="Pending events pagination">
                        <ul class="pagination pagination-sm justify-content-end mt-2 mb-0">
                            <li class="page-item @(!Model.PendingEvents.HasPreviousPage ? "disabled" : "")">
                                <a class="page-link" href="@Url.Action("ApprovePublicEvents", "Admin", new { pendingPage = Model.PendingEvents.CurrentPage - 1, approvedPage = Model.ApprovedEvents.CurrentPage, deniedPage = Model.DeniedEvents.CurrentPage })#pending-section">Previous</a>
                            </li>
                            @for (int i = 1; i <= Model.PendingEvents.TotalPages; i++)
                            {
                                <li class="page-item @(i == Model.PendingEvents.CurrentPage ? "active" : "")">
                                    <a class="page-link" href="@Url.Action("ApprovePublicEvents", "Admin", new { pendingPage = i, approvedPage = Model.ApprovedEvents.CurrentPage, deniedPage = Model.DeniedEvents.CurrentPage })#pending-section">@i</a>
                                </li>
                            }
                            <li class="page-item @(!Model.PendingEvents.HasNextPage ? "disabled" : "")">
                                <a class="page-link" href="@Url.Action("ApprovePublicEvents", "Admin", new { pendingPage = Model.PendingEvents.CurrentPage + 1, approvedPage = Model.ApprovedEvents.CurrentPage, deniedPage = Model.DeniedEvents.CurrentPage })#pending-section">Next</a>
                            </li>
                        </ul>
                    </nav>
                }
            }
            else
            {
                <p class="text-muted mb-0">No events pending approval.</p>
            }
        </div>
    </div>

    <!-- Approved Events Section -->
    <div class="card shadow-sm" id="approved-section">
        <div class="card-header bg-success">
            <h5 class="mb-0 text-white">Approved Events</h5>
        </div>
        <div class="card-body">
            @if (Model.ApprovedEvents.TotalCount > 0)
            {
                <p class="text-muted small mb-3">@Model.ApprovedEvents.TotalCount event(s) approved</p>
                <div class="table-responsive">
                    <table class="table align-middle">
                        <thead>
                            <tr>
                                <th>Title</th>
                                <th>Group</th>
                                <th>Date</th>
                                <th>Time</th>
                                <th>Created By</th>
                                <th class="text-end">Actions</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var evt in Model.ApprovedEvents.Items)
                            {
                                <tr>
                                    <td><strong>@evt.Title</strong></td>
                                    <td>@evt.Group?.Name</td>
                                    <td>@evt.DateOfEvent.ToString("yyyy-MM-dd")</td>
                                    <td>
                                        @if (evt.IsAllDay)
                                        {
                                            <span>All day</span>
                                        }
                                        else
                                        {
                                            <span>@evt.StartTime.ToString("hh\\:mm") - @evt.EndTime.ToString("hh\\:mm")</span>
                                        }
                                    </td>
                                    <td>
                                        @if (evt.CreatedByUser != null)
                                        {
                                            <small>@evt.CreatedByUser.UserName</small>
                                        }
                                    </td>
                                    <td class="text-end">
                                        <a class="btn btn-sm btn-outline-primary" href="@Url.Action("Details", "Events", new { eventId = evt.Id })">Review Event</a>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
                @if (Model.ApprovedEvents.TotalPages > 1)
                {
                    <nav aria-label="Approved events pagination">
                        <ul class="pagination pagination-sm justify-content-end mt-2 mb-0">
                            <li class="page-item @(!Model.ApprovedEvents.HasPreviousPage ? "disabled" : "")">
                                <a class="page-link" href="@Url.Action("ApprovePublicEvents", "Admin", new { pendingPage = Model.PendingEvents.CurrentPage, approvedPage = Model.ApprovedEvents.CurrentPage - 1, deniedPage = Model.DeniedEvents.CurrentPage })#approved-section">Previous</a>
                            </li>
                            @for (int i = 1; i <= Model.ApprovedEvents.TotalPages; i++)
                            {
                                <li class="page-item @(i == Model.ApprovedEvents.CurrentPage ? "active" : "")">
                                    <a class="page-link" href="@Url.Action("ApprovePublicEvents", "Admin", new { pendingPage = Model.PendingEvents.CurrentPage, approvedPage = i, deniedPage = Model.DeniedEvents.CurrentPage })#approved-section">@i</a>
                                </li>
                            }
                            <li class="page-item @(!Model.ApprovedEvents.HasNextPage ? "disabled" : "")">
                                <a class="page-link" href="@Url.Action("ApprovePublicEvents", "Admin", new { pendingPage = Model.PendingEvents.CurrentPage, approvedPage = Model.ApprovedEvents.CurrentPage + 1, deniedPage = Model.DeniedEvents.CurrentPage })#approved-section">Next</a>
                            </li>
                        </ul>
                    </nav>
                }
            }
            else
            {
                <p class="text-muted mb-0">No approved events.</p>
            }
        </div>
    </div>

    <!-- Denied Events Section -->
    <div class="card shadow-sm mt-4" id="denied-section">
        <div class="card-header bg-danger">
            <h5 class="mb-0 text-white">Denied Events</h5>
        </div>
        <div class="card-body">
            @if (Model.DeniedEvents.TotalCount > 0)
            {
                <p class="text-muted small mb-3">@Model.DeniedEvents.TotalCount event(s) denied</p>
                <div class="table-responsive">
                    <table class="table align-middle">
                        <thead>
                            <tr>
                                <th>Title</th>
                                <th>Group</th>
                                <th>Date</th>
                                <th>Time</th>
                                <th>Created By</th>
                                <th class="text-end">Actions</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var evt in Model.DeniedEvents.Items)
                            {
                                <tr>
                                    <td><strong>@evt.Title</strong></td>
                                    <td>@evt.Group?.Name</td>
                                    <td>@evt.DateOfEvent.ToString("yyyy-MM-dd")</td>
                                    <td>
                                        @if (evt.IsAllDay)
                                        {
                                            <span>All day</span>
                                        }
                                        else
                                        {
                                            <span>@evt.StartTime.ToString("hh\\:mm") - @evt.EndTime.ToString("hh\\:mm")</span>
                                        }
                                    </td>
                                    <td>
                                        @if (evt.CreatedByUser != null)
                                        {
                                            <small>@evt.CreatedByUser.UserName</small>
                                        }
                                    </td>
                                    <td class="text-end">
                                        <a class="btn btn-sm btn-outline-primary" href="@Url.Action("Details", "Events", new { eventId = evt.Id })">Review Event</a>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
                @if (Model.DeniedEvents.TotalPages > 1)
                {
                    <nav aria-label="Denied events pagination">
                        <ul class="pagination pagination-sm justify-content-end mt-2 mb-0">
                            <li class="page-item @(!Model.DeniedEvents.HasPreviousPage ? "disabled" : "")">
                                <a class="page-link" href="@Url.Action("ApprovePublicEvents", "Admin", new { pendingPage = Model.PendingEvents.CurrentPage, approvedPage = Model.ApprovedEvents.CurrentPage, deniedPage = Model.DeniedEvents.CurrentPage - 1 })#denied-section">Previous</a>
                            </li>
                            @for (int i = 1; i <= Model.DeniedEvents.TotalPages; i++)
                            {
                                <li class="page-item @(i == Model.DeniedEvents.CurrentPage ? "active" : "")">
                                    <a class="page-link" href="@Url.Action("ApprovePublicEvents", "Admin", new { pendingPage = Model.PendingEvents.CurrentPage, approvedPage = Model.ApprovedEvents.CurrentPage, deniedPage = i })#denied-section">@i</a>
                                </li>
                            }
                            <li class="page-item @(!Model.DeniedEvents.HasNextPage ? "disabled" : "")">
                                <a class="page-link" href="@Url.Action("ApprovePublicEvents", "Admin", new { pendingPage = Model.PendingEvents.CurrentPage, approvedPage = Model.ApprovedEvents.CurrentPage, deniedPage = Model.DeniedEvents.CurrentPage + 1 })#denied-section">Next</a>
                            </li>
                        </ul>
                    </nav>
                }
            }
            else
            {
                <p class="text-muted mb-0">No denied events.</p>
            }
        </div>
    </div>
</div>
