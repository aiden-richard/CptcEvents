@using System.Linq
@model CptcEvents.Models.ViewModels.ApprovePublicEventsViewModel

@{
    ViewData["Title"] = "Approve Public Events";
}

<div class="page-shell">
    <div class="d-flex justify-content-between align-items-start flex-wrap gap-2 mb-3">
        <div>
            <p class="text-muted small mb-1">Admin</p>
            <h2 class="mb-0">Approve Public Events</h2>
        </div>
        <div class="d-flex flex-wrap gap-2">
            <a class="btn btn-outline-secondary" href="@Url.Action("Index", "Admin")">Back to admin</a>
        </div>
    </div>

    <!-- Pending Approval Section -->
    <div class="card shadow-sm mb-4">
        <div class="card-header bg-warning text-dark">
            <h5 class="mb-0">Pending Approval</h5>
        </div>
        <div class="card-body">
            @if (Model.PendingEvents.Any())
            {
                <p class="text-muted small mb-3">@Model.PendingEvents.Count() event(s) pending approval</p>
                <div class="table-responsive">
                    <table class="table align-middle">
                        <thead>
                            <tr>
                                <th>Title</th>
                                <th>Group</th>
                                <th>Date</th>
                                <th>Time</th>
                                <th>Created By</th>
                                <th class="text-end">Actions</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (Event evt in Model.PendingEvents)
                            {
                                <tr>
                                    <td><strong>@evt.Title</strong></td>
                                    <td>@evt.Group?.Name</td>
                                    <td>@evt.DateOfEvent.ToString("yyyy-MM-dd")</td>
                                    <td>
                                        @if (evt.IsAllDay)
                                        {
                                            <span>All day</span>
                                        }
                                        else
                                        {
                                            <span>@evt.StartTime.ToString("hh\\:mm") - @evt.EndTime.ToString("hh\\:mm")</span>
                                        }
                                    </td>
                                    <td>
                                        @if (evt.CreatedByUser != null)
                                        {
                                            <small>@evt.CreatedByUser.UserName</small>
                                        }
                                    </td>
                                    <td class="text-end">
                                        <a class="btn btn-sm btn-outline-primary" href="@Url.Action("Details", "Events", new { eventId = evt.Id })">Review Event</a>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
            else
            {
                <p class="text-muted mb-0">No events pending approval.</p>
            }
        </div>
    </div>

    <!-- Approved Events Section -->
    <div class="card shadow-sm">
        <div class="card-header bg-success">
            <h5 class="mb-0 text-white">Approved Events</h5>
        </div>
        <div class="card-body">
            @if (Model.ApprovedEvents.Any())
            {
                <p class="text-muted small mb-3">@Model.ApprovedEvents.Count() event(s) approved</p>
                <div class="table-responsive">
                    <table class="table align-middle">
                        <thead>
                            <tr>
                                <th>Title</th>
                                <th>Group</th>
                                <th>Date</th>
                                <th>Time</th>
                                <th>Created By</th>
                                <th class="text-end">Actions</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var evt in Model.ApprovedEvents)
                            {
                                <tr>
                                    <td><strong>@evt.Title</strong></td>
                                    <td>@evt.Group?.Name</td>
                                    <td>@evt.DateOfEvent.ToString("yyyy-MM-dd")</td>
                                    <td>
                                        @if (evt.IsAllDay)
                                        {
                                            <span>All day</span>
                                        }
                                        else
                                        {
                                            <span>@evt.StartTime.ToString("hh\\:mm") - @evt.EndTime.ToString("hh\\:mm")</span>
                                        }
                                    </td>
                                    <td>
                                        @if (evt.CreatedByUser != null)
                                        {
                                            <small>@evt.CreatedByUser.UserName</small>
                                        }
                                    </td>
                                    <td class="text-end">
                                        <a class="btn btn-sm btn-outline-primary" href="@Url.Action("Details", "Events", new { eventId = evt.Id })">Review Event</a>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
            else
            {
                <p class="text-muted mb-0">No approved events.</p>
            }
        </div>
    </div>

    <!-- Denied Events Section -->
    <div class="card shadow-sm mt-4">
        <div class="card-header bg-danger">
            <h5 class="mb-0 text-white">Denied Events</h5>
        </div>
        <div class="card-body">
            @if (Model.DeniedEvents.Any())
            {
                <p class="text-muted small mb-3">@Model.DeniedEvents.Count() event(s) denied</p>
                <div class="table-responsive">
                    <table class="table align-middle">
                        <thead>
                            <tr>
                                <th>Title</th>
                                <th>Group</th>
                                <th>Date</th>
                                <th>Time</th>
                                <th>Created By</th>
                                <th class="text-end">Actions</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var evt in Model.DeniedEvents)
                            {
                                <tr>
                                    <td><strong>@evt.Title</strong></td>
                                    <td>@evt.Group?.Name</td>
                                    <td>@evt.DateOfEvent.ToString("yyyy-MM-dd")</td>
                                    <td>
                                        @if (evt.IsAllDay)
                                        {
                                            <span>All day</span>
                                        }
                                        else
                                        {
                                            <span>@evt.StartTime.ToString("hh\\:mm") - @evt.EndTime.ToString("hh\\:mm")</span>
                                        }
                                    </td>
                                    <td>
                                        @if (evt.CreatedByUser != null)
                                        {
                                            <small>@evt.CreatedByUser.UserName</small>
                                        }
                                    </td>
                                    <td class="text-end">
                                        <a class="btn btn-sm btn-outline-primary" href="@Url.Action("Details", "Events", new { eventId = evt.Id })">Review Event</a>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
            else
            {
                <p class="text-muted mb-0">No denied events.</p>
            }
        </div>
    </div>
</div>
