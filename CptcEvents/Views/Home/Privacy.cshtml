@{
    ViewData["Title"] = "Privacy Policy";
}

<div class="container py-4">
    <h1>@ViewData["Title"]</h1>
    <p class="text-muted">Last updated: March 2026</p>

    <section class="mt-4">
        <h2>Information We Collect</h2>
        <p>We collect information you provide when registering for an account or signing up for events, including your name and email address.</p>
    </section>

    <section class="mt-4">
        <h2>How We Use Your Information</h2>
        <ul>
            <li>To manage your account and event registrations</li>
            <li>To send notifications about events you have registered for</li>
            <li>To communicate important updates about the platform</li>
        </ul>
    </section>

    <section class="mt-4">
        <h2>Data Sharing</h2>
        <p>We do not sell or share your personal information with third parties except as required by law.</p>
    </section>

    <section class="mt-4">
        <h2>Contact</h2>
        <p>If you have questions about this privacy policy, please contact the site administrator.</p>
    </section>
</div>
